# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly declare common text file types
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.env       text eol=lf
*.sh        text eol=lf

# Declare binary files to prevent corruption
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.ico       binary
